NEXT_PUBLIC_SHARE_TOKEN=0x
NEXT_PUBLIC_MARKETPLACE=0x
NEXT_PUBLIC_YIELD_SPLITTER=0x
NEXT_PUBLIC_GOVERNANCE=0x
